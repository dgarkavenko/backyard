{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(mkdir -p /c/nexss/Plugins && git clone https://github.com/VoxelPlugin/VoxelPluginFreeLegacy.git /c/nexss/Plugins/VoxelFree)",
      "WebSearch",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:medium.com)",
      "Bash(grep:*)",
      "Bash(cd:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs",
      "Bash(uv --version)",
      "Bash(where uv:*)",
      "Bash(git clone:*)",
      "Bash(sleep:*)",
      "Bash(tail:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import sys,json; d=json.load(sys.stdin); p=d.get('tool_input',{}).get('file_path','') or d.get('tool_response',{}).get('filePath',''); exit(0 if p.endswith('.as') else 1)\" && sleep 3 && tail -30 \"C:/backyard/Saved/Logs/BackyardForge.log\" | grep -i -E \"(Error|Warning|Compiling|Hot reload)\" || true",
            "timeout": 10,
            "statusMessage": "Checking AngelScript compilation..."
          }
        ]
      }
    ]
  }
}
